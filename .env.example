# Copy to .env.local (gitignored) so /setup-openfx can read your credentials
# without you typing secrets into the shell. The skill sources this file.

# --- Tesser workspace credentials ---
# You normally do NOT fill these by hand. In Phase 0 the skill auto-parses them from the
# API-keys file you download (Tesser dashboard > Settings > API keys, a tesser-credentials*.env
# file) and move into this directory:  CLIENT_ID -> TESSER_API_KEY, CLIENT_SECRET -> TESSER_API_SECRET.
TESSER_API_KEY=
TESSER_API_SECRET=
# Demo-style names are also accepted: TESSER_CLIENT_ID / TESSER_CLIENT_SECRET

# --- Environment (optional) ---
# Defaults target sandbox. For production, set both:
# TESSER_BASE_URL=https://api.tesser.xyz
# TESSER_AUTH_URL=https://tesser-payments.us.auth0.com/oauth/token

# --- OpenFX credentials ---
# You normally do NOT fill these by hand. In Phase 1 the skill auto-parses the first
# three from the OpenFX key file you download and move into this directory
# (OpenFX_api-key_*.json):  id -> OPENFX_API_KEY, orgId -> OPENFX_ORG_ID,
# privateKey -> OPENFX_PRIVATE_KEY.
OPENFX_ORG_ID=
OPENFX_API_KEY=
OPENFX_PRIVATE_KEY=
# OPENFX_WEBHOOK_SECRET is the one you paste by hand: register the webhook URL the skill
# shows you, then copy the Signing Key OpenFX returns.
OPENFX_WEBHOOK_SECRET=
